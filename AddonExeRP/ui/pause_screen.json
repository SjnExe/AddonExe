{
    "namespace": "pause_screen",

    "players_panel_content@pause_screen.players_panel_content": {
        "modifications": [
            {
                "control_name": "players_grid",
                "factory": {
                    "name": "player_list_entry_factory",
                    "control_name": "player_list_entry",
                    "collection_name": "$players_list",
                    "collection_condition": "query.is_local_player or query.not_has_tag('vanished')"
                }
            }
        ]
    },

    "store_button@pause.pause_button_template": {
      "$pressed_button_name": "button.menu_settings",
      "$button_text": "menu.settings",
      "bindings": []
    },

    "store_error_button": {
      "visible": false
    },

    "marketplace_button_content": {
        "type": "stack_panel",
        "orientation": "horizontal",
        "anchor_from": "center",
        "anchor_to": "center",
        "controls": [
            {
                "icon": {
                    "type": "image",
                    "texture": "textures/ui/sidebar_icons/marketplace",
                    "size": [ 16, 16 ]
                }
            },
            { "padding": { "type": "panel", "size": [ 4, 0 ] } },
            {
                "label": {
                    "type": "label",
                    "text": "Marketplace"
                }
            }
        ]
    },

    "settings_button@common_buttons.light_content_button": {
        "$button_content": "pause_screen.marketplace_button_content",
        "$pressed_button_name": "button.menu_store",
        "size": [ "100%", 28 ]
    }
}

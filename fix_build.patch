        for await (const file of outGlob.scan({ cwd: outDirScripts })) {
            const oldPath = path.join(outDirScripts, file);
            const newPath = oldPath.replace('.default.js', '.js');

            if (fs.existsSync(newPath)) {
                fs.rmSync(oldPath);
                if (fs.existsSync(oldPath + '.map')) fs.rmSync(oldPath + '.map');
            } else {
                fs.renameSync(oldPath, newPath);
                if (fs.existsSync(oldPath + '.map')) fs.renameSync(oldPath + '.map', newPath + '.map');

            const forwardSlashFile = file.replace(/\\/g, '/');
            let relativePath = forwardSlashFile.replace('src/', './').replace('.ts', '.js');
            if (relativePath.endsWith('.default.js')) {
                relativePath = relativePath.replace('.default.js', '.js');
            }
            return relativePath;

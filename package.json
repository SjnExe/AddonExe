{
    "name": "AddonExe",
    "version": "0.7.0",
    "private": true,
    "description": "<p align=\"center\"> <h1 align=\"center\">AddonExe for Minecraft BE</h1> </p>",
    "keywords": [],
    "homepage": "https://github.com/SjnExe/AddonExe#readme",
    "bugs": {
        "url": "https://github.com/SjnExe/AddonExe/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/SjnExe/AddonExe.git"
    },
    "license": "MIT",
    "author": "SjnExe",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "build": "bun run clean && bun scripts/generate-manifests.js && bun scripts/build-assets.js && tsup --env.NODE_ENV=development",
        "build:release": "bun run clean && bun scripts/generate-manifests.js --release && bun scripts/build-assets.js --minify && tsup --minify --env.NODE_ENV=production",
        "check-deps": "bun scripts/check-dependencies.js",
        "check-types": "tsc --noEmit",
        "clean": "rimraf build",
        "fix-project": "mct fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint src scripts eslint.config.js",
        "lint:check": "eslint src scripts eslint.config.js",
        "lint:fix": "eslint src scripts eslint.config.js --fix",
        "lint:report": "eslint src scripts eslint.config.js --output-file eslint_report.txt",
        "prepare": "simple-git-hooks && bun scripts/generate-manifests.js",
        "project-info": "mct info",
        "reinstall": "rm -rf node_modules bun.lock && bun install",
        "test": "vitest run --passWithNoTests",
        "test:duplication": "jscpd src/ --min-lines 5 --min-tokens 40 --max-lines 1000 --ignore 'src/**/__tests__/**'",
        "validate": "bun run check-deps && mct validate default PRJINT,UNKJSON,pathlength,PATHLENGTH,BASEGAMEVER,WPACKREFS,JSON,STRICT,ENTITYTYPE,FORMATVER,ITEMTYPE,CHKMANIF,FORBFILE -i build",
        "validate:report": "bun run check-deps && mct validate default PRJINT,UNKJSON,pathlength,PATHLENGTH,BASEGAMEVER,WPACKREFS,JSON,STRICT,ENTITYTYPE,FORMATVER,ITEMTYPE,CHKMANIF,FORBFILE -i build -o validation_report",
        "watch": "concurrently \"tsc -w\" \"bun scripts/build-assets.js --watch\" \"tsup --watch --env.NODE_ENV=development\""
    },
    "simple-git-hooks": {
        "pre-commit": "bunx lint-staged"
    },
    "lint-staged": {
        "*.{js,ts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": "prettier --write"
    },
    "overrides": {
        "react": "^18.2.0"
    },
    "devDependencies": {
        "@eslint/js": "latest",
        "@minecraft/common": "latest",
        "@minecraft/creator-tools": "latest",
        "@minecraft/debug-utilities": "beta",
        "@minecraft/math": "latest",
        "@minecraft/server": "beta",
        "@minecraft/server-gametest": "beta",
        "@minecraft/server-ui": "beta",
        "@minecraft/vanilla-data": "latest",
        "@types/node": "latest",
        "@typescript-eslint/eslint-plugin": "latest",
        "@typescript-eslint/parser": "latest",
        "chokidar": "latest",
        "concurrently": "latest",
        "esbuild": "latest",
        "eslint": "latest",
        "eslint-config-prettier": "latest",
        "eslint-import-resolver-typescript": "latest",
        "eslint-plugin-import": "latest",
        "eslint-plugin-jsonc": "latest",
        "eslint-plugin-minecraft-linting": "latest",
        "glob": "latest",
        "globals": "latest",
        "jscpd": "latest",
        "lint-staged": "latest",
        "prettier": "latest",
        "prettier-plugin-organize-imports": "latest",
        "prettier-plugin-packagejson": "latest",
        "rimraf": "latest",
        "simple-git-hooks": "latest",
        "tsup": "latest",
        "type-fest": "latest",
        "typescript": "latest",
        "typescript-eslint": "latest",
        "vitest": "latest"
    }
}

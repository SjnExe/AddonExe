{
    "name": "AddonExe",
    "version": "0.7.0",
    "private": true,
    "description": "<p align=\"center\"> <h1 align=\"center\">AddonExe for Minecraft BE</h1> </p>",
    "keywords": [],
    "homepage": "https://github.com/SjnExe/AddonExe#readme",
    "bugs": {
        "url": "https://github.com/SjnExe/AddonExe/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/SjnExe/AddonExe.git"
    },
    "license": "MIT",
    "author": "SjnExe",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "build": "bun clean && bun scripts/generate-manifests.js && bun scripts/build-assets.js && bun --bun tsup --env.NODE_ENV=development",
        "build:release": "bun clean && bun scripts/generate-manifests.js --release && bun scripts/build-assets.js --minify && bun --bun tsup --minify --env.NODE_ENV=production",
        "check-deps": "bun scripts/check-dependencies.js",
        "check-types": "bun --bun tsc --noEmit --incremental",
        "clean": "rm -rf build out",
        "fix-project": "bun --bun mct fix",
        "format": "bun --bun prettier --write --cache .",
        "format:check": "bun --bun prettier --check --cache .",
        "postinstall": "if [ -d /data/data/com.termux ]; then if command -v cargo >/dev/null 2>&1; then echo 'Termux detected: Checking native jscpd via Cargo...' && cargo install jscpd; else echo '\n⚠️  [Termux Warning]: cargo not found. Run \"pkg install rust\" to enable jscpd support.\n'; fi; fi",
        "lint": "bun --bun eslint src scripts eslint.config.js --cache",
        "lint:check": "bun --bun eslint src scripts eslint.config.js --cache",
        "lint:fix": "bun --bun eslint src scripts eslint.config.js --fix --cache",
        "lint:report": "bun --bun eslint src scripts eslint.config.js --output-file eslint_report.txt --cache",
        "prepare": "simple-git-hooks && bun scripts/generate-manifests.js",
        "project-info": "bun --bun mct info",
        "reinstall": "rm -rf node_modules bun.lock && bun install",
        "test": "bun --bun vitest run --passWithNoTests",
        "test:duplication": "if [ -d /data/data/com.termux ]; then $HOME/.cargo/bin/jscpd src/ --min-lines 5 --min-tokens 40 --max-lines 1000 --ignore 'src/**/__tests__/**'; else jscpd src/ --min-lines 5 --min-tokens 40 --max-lines 1000 --ignore 'src/**/__tests__/**'; fi",
        "validate": "bun check-deps && bun --bun mct validate default PRJINT,UNKJSON,pathlength,PATHLENGTH,BASEGAMEVER,WPACKREFS,JSON,STRICT,ENTITYTYPE,FORMATVER,ITEMTYPE,CHKMANIF,FORBFILE -i build",
        "validate:report": "bun check-deps && bun --bun mct validate default PRJINT,UNKJSON,pathlength,PATHLENGTH,BASEGAMEVER,WPACKREFS,JSON,STRICT,ENTITYTYPE,FORMATVER,ITEMTYPE,CHKMANIF,FORBFILE -i build -o validation_report",
        "watch": "bun --bun concurrently \"bun --bun tsc -w\" \"bun scripts/build-assets.js --watch\" \"bun --bun tsup --watch --env.NODE_ENV=development\""
    },
    "simple-git-hooks": {
        "pre-commit": "bun --bun lint-staged"
    },
    "lint-staged": {
        "*.{js,ts}": [
            "bun --bun eslint --fix",
            "bun --bun prettier --write"
        ],
        "*.{json,md}": "bun --bun prettier --write"
    },
    "overrides": {
        "react": "^18.2.0"
    },
    "devDependencies": {
        "@eslint/js": "latest",
        "@minecraft/common": "latest",
        "@minecraft/creator-tools": "latest",
        "@minecraft/debug-utilities": "beta",
        "@minecraft/math": "latest",
        "@minecraft/server": "beta",
        "@minecraft/server-gametest": "beta",
        "@minecraft/server-ui": "beta",
        "@minecraft/vanilla-data": "latest",
        "@types/node": "latest",
        "@typescript-eslint/eslint-plugin": "latest",
        "@typescript-eslint/parser": "latest",
        "chokidar": "latest",
        "concurrently": "latest",
        "esbuild": "latest",
        "eslint": "latest",
        "eslint-config-prettier": "latest",
        "eslint-import-resolver-typescript": "latest",
        "eslint-plugin-import": "latest",
        "eslint-plugin-jsonc": "latest",
        "eslint-plugin-minecraft-linting": "latest",
        "glob": "latest",
        "globals": "latest",
        "jscpd": "latest",
        "lint-staged": "latest",
        "prettier": "latest",
        "prettier-plugin-organize-imports": "latest",
        "prettier-plugin-packagejson": "latest",
        "rimraf": "latest",
        "simple-git-hooks": "latest",
        "tsup": "latest",
        "type-fest": "latest",
        "typescript": "latest",
        "typescript-eslint": "latest",
        "vitest": "latest"
    },
    "trustedDependencies": [
        "bufferutil",
        "esbuild",
        "simple-git-hooks",
        "unrs-resolver",
        "utf-8-validate"
    ]
}

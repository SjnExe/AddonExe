{
    "name": "app",
    "version": "0.7.0",
    "description": "<p align=\"center\">   <!-- TODO: Add a cool project logo/banner here. Example: <img src=\"link_to_your_logo.png\" alt=\"AddonExe Logo\" width=\"200\"/> -->   <h1 align=\"center\">AddonExe for Minecraft BE</h1> </p>",
    "main": "index.js",
    "scripts": {
        "clean": "rimraf packs/behavior/scripts",
        "reinstall": "rm -rf node_modules package-lock.json && npm install",
        "check-types": "tsc --noEmit",
        "build": "npm run clean && node scripts/generate-command-index.js && node scripts/generate-manifests.js && node scripts/build.js",
        "build:release": "npm run clean && node scripts/generate-command-index.js && node scripts/generate-manifests.js --release && node scripts/build.js --minify",
        "watch": "node scripts/generate-command-index.js && concurrently \"tsc -w\" \"node scripts/build.js --watch\"",
        "test": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests",
        "lint": "eslint src scripts eslint.config.js && npm run check-types",
        "lint:check": "eslint src scripts eslint.config.js && npm run check-types && prettier --check .",
        "lint:fix": "eslint src scripts eslint.config.js --fix && prettier --write . && npm run check-types",
        "lint:report": "eslint src scripts eslint.config.js --output-file eslint_report.txt",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "check-deps": "node scripts/check-dependencies.js",
        "validate": "npm run check-deps && npx mct validate default PRJINT,UNKJSON,pathlength,PATHLENGTH,BASEGAMEVER,CHKMANIF,WPACKREFS,JSON,STRICT,ENTITYTYPE,FORMATVER,ITEMTYPE --display-only",
        "validate:report": "npm run check-deps && npx mct validate default PRJINT,UNKJSON,pathlength,PATHLENGTH,BASEGAMEVER,CHKMANIF,WPACKREFS,JSON,STRICT,ENTITYTYPE,FORMATVER,ITEMTYPE -o validation_report",
        "project-info": "npx mct info",
        "fix-project": "npx mct fix",
        "prepare": "npx simple-git-hooks && node scripts/generate-manifests.js"
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/SjnExe/AddonExe.git"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "bugs": {
        "url": "https://github.com/SjnExe/AddonExe/issues"
    },
    "homepage": "https://github.com/SjnExe/AddonExe#readme",
    "devDependencies": {
        "@babel/preset-env": "latest",
        "@eslint/eslintrc": "latest",
        "@eslint/js": "latest",
        "@minecraft/common": "latest",
        "@minecraft/core-build-tasks": "latest",
        "@minecraft/creator-tools": "latest",
        "@minecraft/debug-utilities": "beta",
        "@minecraft/math": "latest",
        "@minecraft/server": "beta",
        "@minecraft/server-gametest": "beta",
        "@minecraft/server-ui": "beta",
        "@minecraft/vanilla-data": "latest",
        "@types/jest": "latest",
        "@types/node": "latest",
        "@typescript-eslint/eslint-plugin": "latest",
        "@typescript-eslint/parser": "latest",
        "babel-jest": "latest",
        "chokidar": "latest",
        "concurrently": "latest",
        "esbuild": "latest",
        "eslint": "latest",
        "eslint-config-prettier": "latest",
        "eslint-import-resolver-typescript": "latest",
        "eslint-plugin-import": "latest",
        "eslint-plugin-jsonc": "latest",
        "eslint-plugin-minecraft-linting": "latest",
        "glob": "latest",
        "globals": "latest",
        "jest": "latest",
        "lint-staged": "latest",
        "prettier": "latest",
        "prettier-plugin-organize-imports": "latest",
        "rimraf": "latest",
        "simple-git-hooks": "latest",
        "ts-jest": "latest",
        "type-fest": "latest",
        "typescript": "latest",
        "typescript-eslint": "latest"
    },
    "jest": {
        "preset": "ts-jest/presets/default-esm",
        "testEnvironment": "node",
        "extensionsToTreatAsEsm": [
            ".ts"
        ],
        "moduleNameMapper": {
            "^(\\.{1,2}/.*)\\.js$": "$1",
            "^@minecraft/server$": "<rootDir>/src/core/__tests__/__mocks__/minecraftMock.ts",
            "^@minecraft/server-ui$": "<rootDir>/src/core/__tests__/__mocks__/minecraftMock.ts",
            "^@minecraft/diagnostics$": "<rootDir>/src/core/__tests__/__mocks__/minecraftMock.ts",
            "^@core/(.*)\\.js$": "<rootDir>/src/core/$1",
            "^@features/(.*)\\.js$": "<rootDir>/src/features/$1",
            "^@ui/(.*)\\.js$": "<rootDir>/src/core/ui/$1",
            "^@commands/(.*)\\.js$": "<rootDir>/src/core/commands/$1",
            "^@lib/(.*)\\.js$": "<rootDir>/src/lib/$1"
        },
        "transform": {
            "^.+\\.tsx?$": [
                "ts-jest",
                {
                    "useESM": true,
                    "tsconfig": "tsconfig.test.json"
                }
            ],
            "^.+\\.js$": "babel-jest"
        },
        "testPathIgnorePatterns": [
            "/node_modules/",
            "/packs/behavior/scripts/",
            "/__mocks__/",
            "<rootDir>/src/features/essentials/commands/test.ts"
        ],
        "transformIgnorePatterns": [
            "node_modules/(?!@minecraft)"
        ]
    },
    "lint-staged": {
        "*.{js,ts}": "eslint --fix",
        "*.{js,ts,json,md}": "prettier --write"
    },
    "overrides": {
        "@minecraft/common": "latest",
        "@minecraft/debug-utilities": "beta",
        "@minecraft/server": "beta",
        "@minecraft/server-gametest": "beta",
        "@minecraft/server-ui": "beta",
        "@minecraft/vanilla-data": "latest"
    }
}

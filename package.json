{
    "name": "AddonExe",
    "version": "0.7.0",
    "private": true,
    "description": "<p align=\"center\"> <h1 align=\"center\">AddonExe for Minecraft BE</h1> </p>",
    "keywords": [],
    "homepage": "https://github.com/SjnExe/AddonExe#readme",
    "bugs": {
        "url": "https://github.com/SjnExe/AddonExe/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/SjnExe/AddonExe.git"
    },
    "license": "MIT",
    "author": "SjnExe",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "build": "npm run clean && node scripts/generate-feature-registry.js && node scripts/generate-manifests.js && node scripts/build-assets.js && tsup",
        "build:release": "npm run clean && node scripts/generate-feature-registry.js --release && node scripts/generate-manifests.js --release && node scripts/build-assets.js --minify && tsup --minify",
        "check-deps": "node scripts/check-dependencies.js",
        "check-types": "tsc --noEmit",
        "clean": "rimraf build",
        "fix-project": "npx mct fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint src scripts eslint.config.js",
        "lint:check": "eslint src scripts eslint.config.js",
        "lint:fix": "eslint src scripts eslint.config.js --fix",
        "lint:report": "eslint src scripts eslint.config.js --output-file eslint_report.txt",
        "prepare": "npx simple-git-hooks && node scripts/generate-manifests.js",
        "project-info": "npx mct info",
        "reinstall": "rm -rf node_modules package-lock.json && npm install",
        "test": "vitest run --passWithNoTests",
        "test:duplication": "jscpd src/ --min-lines 5 --min-tokens 40 --max-lines 1000 --ignore 'src/**/__tests__/**'",
        "validate": "npm run check-deps && npx mct validate default PRJINT,UNKJSON,pathlength,PATHLENGTH,BASEGAMEVER,WPACKREFS,JSON,STRICT,ENTITYTYPE,FORMATVER,ITEMTYPE,CHKMANIF,FORBFILE -i build --display-only",
        "validate:report": "npm run check-deps && npx mct validate default PRJINT,UNKJSON,pathlength,PATHLENGTH,BASEGAMEVER,WPACKREFS,JSON,STRICT,ENTITYTYPE,FORMATVER,ITEMTYPE,CHKMANIF,FORBFILE -i build -o validation_report",
        "watch": "node scripts/generate-feature-registry.js && concurrently \"tsc -w\" \"node scripts/build-assets.js --watch\" \"tsup --watch\""
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged"
    },
    "lint-staged": {
        "*.{js,ts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": "prettier --write"
    },
    "overrides": {
        "@isaacs/brace-expansion": "latest",
        "@minecraft/common": "latest",
        "@minecraft/debug-utilities": "beta",
        "@minecraft/server": "beta",
        "@minecraft/server-gametest": "beta",
        "@minecraft/server-ui": "beta",
        "@minecraft/vanilla-data": "latest",
        "@octokit/plugin-paginate-rest": "latest",
        "@octokit/request": "latest",
        "@octokit/request-error": "latest",
        "ajv": "6.12.6",
        "axios": "latest",
        "brace-expansion": "latest",
        "flatted": "latest",
        "follow-redirects": "latest",
        "lodash": "latest",
        "minimatch": "latest",
        "picomatch": "latest",
        "yaml": "latest"
    },
    "devDependencies": {
        "@eslint/eslintrc": "latest",
        "@eslint/js": "latest",
        "@minecraft/common": "latest",
        "@minecraft/creator-tools": "latest",
        "@minecraft/debug-utilities": "beta",
        "@minecraft/math": "latest",
        "@minecraft/server": "beta",
        "@minecraft/server-gametest": "beta",
        "@minecraft/server-ui": "beta",
        "@minecraft/vanilla-data": "latest",
        "@types/node": "latest",
        "@typescript-eslint/eslint-plugin": "latest",
        "@typescript-eslint/parser": "latest",
        "chokidar": "latest",
        "concurrently": "latest",
        "esbuild": "latest",
        "eslint": "latest",
        "eslint-config-prettier": "latest",
        "eslint-import-resolver-typescript": "latest",
        "eslint-plugin-import": "latest",
        "eslint-plugin-jsonc": "latest",
        "eslint-plugin-minecraft-linting": "latest",
        "glob": "latest",
        "globals": "latest",
        "jscpd": "latest",
        "lint-staged": "latest",
        "prettier": "latest",
        "prettier-plugin-organize-imports": "latest",
        "prettier-plugin-packagejson": "latest",
        "rimraf": "latest",
        "simple-git-hooks": "latest",
        "tsup": "latest",
        "type-fest": "latest",
        "typescript": "latest",
        "typescript-eslint": "latest",
        "vitest": "latest"
    },
    "dependencies": {
        "react": "^19.2.7"
    }
}

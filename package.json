{
    "name": "app",
    "version": "0.7.0",
    "description": "<p align=\"center\">   <!-- TODO: Add a cool project logo/banner here. Example: <img src=\"link_to_your_logo.png\" alt=\"AddonExe Logo\" width=\"200\"/> -->   <h1 align=\"center\">AddonExe for Minecraft BE</h1> </p>",
    "main": "index.js",
    "scripts": {
        "build": "tsc",
        "watch": "tsc -w",
        "test": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js",
        "lint": "eslint . && node scripts/validate-filtered.js",
        "lint:fix": "eslint . --fix",
        "lint:report": "eslint . --output-file eslint_report.txt",
        "format": "prettier --write .",
        "validate": "npx mct validate default PRJINT,UNKJSON,pathlength,PATHLENGTH,BASEGAMEVER,CHKMANIF,WPACKREFS,JSON,STRICT,ENTITYTYPE,FORMATVER,ITEMTYPE --display-only",
        "validate:report": "npx mct validate default PRJINT,UNKJSON,pathlength,PATHLENGTH,BASEGAMEVER,CHKMANIF,WPACKREFS,JSON,STRICT,ENTITYTYPE,FORMATVER,ITEMTYPE -o validation_report",
        "prepare": "husky"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/SjnExe/AddonExe.git"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "bugs": {
        "url": "https://github.com/SjnExe/AddonExe/issues"
    },
    "homepage": "https://github.com/SjnExe/AddonExe#readme",
    "devDependencies": {
        "@babel/preset-env": "latest",
        "@eslint/eslintrc": "latest",
        "@eslint/js": "latest",
        "@minecraft/creator-tools": "latest",
        "@minecraft/math": "latest",
        "@minecraft/vanilla-data": "latest",
        "@minecraft/server-gametest": "beta",
        "@minecraft/common": "latest",
        "@minecraft/diagnostics": "beta",
        "@minecraft/debug-utilities": "beta",
        "@minecraft/gameplay-utilities": "latest",
        "@types/jest": "latest",
        "@types/node": "latest",
        "@typescript-eslint/eslint-plugin": "latest",
        "@typescript-eslint/parser": "latest",
        "babel-jest": "latest",
        "eslint": "latest",
        "eslint-config-prettier": "latest",
        "eslint-import-resolver-typescript": "latest",
        "eslint-plugin-import": "latest",
        "eslint-plugin-jsonc": "latest",
        "eslint-plugin-minecraft-linting": "latest",
        "globals": "latest",
        "husky": "latest",
        "jest": "latest",
        "lint-staged": "latest",
        "prettier": "latest",
        "ts-jest": "latest",
        "ts-node": "latest",
        "typescript": "latest",
        "typescript-eslint": "latest"
    },
    "jest": {
        "preset": "ts-jest/presets/default-esm",
        "testEnvironment": "node",
        "extensionsToTreatAsEsm": [
            ".ts"
        ],
        "moduleNameMapper": {
            "^(\\.{1,2}/.*)\\.js$": "$1",
            "^@minecraft/server$": "<rootDir>/src/core/__tests__/__mocks__/minecraftMock.ts",
            "^@minecraft/server-ui$": "<rootDir>/src/core/__tests__/__mocks__/minecraftMock.ts"
        },
        "transform": {
            "^.+\\.tsx?$": [
                "ts-jest",
                {
                    "useESM": true
                }
            ]
        },
        "testPathIgnorePatterns": [
            "/node_modules/",
            "/packs/behavior/scripts/",
            "/__mocks__/"
        ]
    },
    "lint-staged": {
        "*.{js,ts}": "eslint --fix",
        "*.{js,ts,json,md}": "prettier --write"
    },
    "dependencies": {
        "@minecraft/server": "beta",
        "@minecraft/server-ui": "beta"
    },
    "overrides": {
        "@minecraft/server": "beta",
        "@minecraft/server-ui": "beta",
        "@minecraft/server-gametest": "beta",
        "@minecraft/diagnostics": "beta",
        "@minecraft/debug-utilities": "beta",
        "@minecraft/common": "latest",
        "@minecraft/math": "latest",
        "@minecraft/vanilla-data": "latest",
        "@minecraft/gameplay-utilities": "latest"
    }
}

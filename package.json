{
    "name": "app",
    "version": "1.0.0",
    "description": "<p align=\"center\">   <!-- TODO: Add a cool project logo/banner here. Example: <img src=\"link_to_your_logo.png\" alt=\"AddonExe Logo\" width=\"200\"/> -->   <h1 align=\"center\">AddonExe for Minecraft BE</h1> </p>",
    "main": "index.js",
    "scripts": {
        "build": "tsc",
        "watch": "tsc -w",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "lint:report": "eslint . --output-file eslint_report.txt",
        "format": "prettier --write .",
        "validate": "npx mct validate default PRJINT,UNKJSON,pathlength,BASEGAMEVER100,CHKMANIF105 --display-only",
        "validate:report": "npx mct validate default PRJINT,UNKJSON,pathlength,BASEGAMEVER100,CHKMANIF105 -o validation_report",
        "prepare": "husky"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/SjnExe/AddonExe.git"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "bugs": {
        "url": "https://github.com/SjnExe/AddonExe/issues"
    },
    "homepage": "https://github.com/SjnExe/AddonExe#readme",
    "devDependencies": {
        "@babel/preset-env": "npm:@babel/preset-env@latest",
        "@eslint/eslintrc": "npm:@eslint/eslintrc@latest",
        "@eslint/js": "npm:@eslint/js@latest",
        "@minecraft/common": "npm:@minecraft/common@latest",
        "@minecraft/creator-tools": "npm:@minecraft/creator-tools@latest",
        "@minecraft/debug-utilities": "npm:@minecraft/debug-utilities@beta",
        "@minecraft/diagnostics": "npm:@minecraft/diagnostics@beta",
        "@minecraft/gameplay-utilities": "npm:@minecraft/gameplay-utilities@latest",
        "@minecraft/math": "npm:@minecraft/math@latest",
        "@minecraft/server-gametest": "npm:@minecraft/server-gametest@beta",
        "@minecraft/vanilla-data": "npm:@minecraft/vanilla-data@latest",
        "@types/jest": "npm:@types/jest@latest",
        "@types/node": "npm:@types/node@latest",
        "@typescript-eslint/eslint-plugin": "npm:@typescript-eslint/eslint-plugin@latest",
        "@typescript-eslint/parser": "npm:@typescript-eslint/parser@latest",
        "babel-jest": "npm:babel-jest@latest",
        "eslint": "npm:eslint@latest",
        "eslint-config-prettier": "npm:eslint-config-prettier@latest",
        "eslint-import-resolver-typescript": "npm:eslint-import-resolver-typescript@latest",
        "eslint-plugin-import": "npm:eslint-plugin-import@latest",
        "eslint-plugin-jsonc": "npm:eslint-plugin-jsonc@latest",
        "eslint-plugin-minecraft-linting": "npm:eslint-plugin-minecraft-linting@latest",
        "globals": "npm:globals@latest",
        "husky": "npm:husky@latest",
        "jest": "npm:jest@latest",
        "lint-staged": "npm:lint-staged@latest",
        "prettier": "npm:prettier@latest",
        "ts-jest": "npm:ts-jest@latest",
        "ts-node": "npm:ts-node@latest",
        "typescript": "npm:typescript@latest"
    },
    "jest": {
        "preset": "ts-jest/presets/default-esm",
        "testEnvironment": "node",
        "extensionsToTreatAsEsm": [
            ".ts"
        ],
        "moduleNameMapper": {
            "^(\\.{1,2}/.*)\\.js$": "$1"
        },
        "transform": {
            "^.+\\.tsx?$": [
                "ts-jest",
                {
                    "useESM": true
                }
            ]
        },
        "testPathIgnorePatterns": [
            "/node_modules/",
            "/AddonExeBP/scripts/"
        ]
    },
    "lint-staged": {
        "*.{js,ts}": "eslint --fix",
        "*.{js,ts,json,md}": "prettier --write"
    },
    "dependencies": {
        "@minecraft/server": "npm:@minecraft/server@beta",
        "@minecraft/server-ui": "npm:@minecraft/server-ui@beta"
    },
    "overrides": {
        "@minecraft/server": "npm:@minecraft/server@beta",
        "@minecraft/server-ui": "npm:@minecraft/server-ui@beta"
    }
}

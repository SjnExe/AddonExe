{
    "namespace": "server_form",
    "long_form_panel": {
        "type": "panel",
        "bindings": [{ "binding_name": "#title_text" }],
        "controls": [
            {
                "tic_tac_toe_override": {
                    "type": "panel",
                    "bindings": [
                        {
                            "binding_name": "#title_text",
                            "binding_name_override": "#title"
                        }
                    ],
                    "controls": [
                        {
                            "grid_view": {
                                "type": "panel",
                                "layer": 1,
                                "anchor_from": "center",
                                "anchor_to": "center",
                                "size": ["100%", "100%"],
                                "controls": [{ "ttt_screen@addonexe_ttt.grid_screen": {} }]
                            }
                        }
                    ],
                    "visible": "($title_text = '§t§t§tTic Tac Toe')"
                }
            },
            {
                "default_view": {
                    "type": "stack_panel",
                    "size": ["100%", "100%"],
                    "orientation": "vertical",
                    "layer": 1,
                    "anchor_from": "top_left",
                    "anchor_to": "top_left",
                    "controls": [
                        {
                            "scrolling_panel@common.scrolling_panel": {
                                "anchor_to": "top_left",
                                "anchor_from": "top_left",
                                "$show_background": false,
                                "size": ["100%", "100%"],
                                "$scrolling_content": "server_form.long_form_scrolling_content",
                                "$scroll_size": [5, "100% - 4px"],
                                "$scrolling_pane_size": ["100% - 4px", "100% - 2px"],
                                "$scrolling_pane_offset": [2, 0],
                                "$scroll_bar_right_padding_size": [0, 0]
                            }
                        }
                    ],
                    "visible": "(not ($title_text = '§t§t§tTic Tac Toe'))"
                }
            }
        ]
    }
}

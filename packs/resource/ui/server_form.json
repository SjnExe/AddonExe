{
    "namespace": "server_form",
    "long_form": {
        "type": "panel",
        "bindings": [
            { "binding_name": "#title_text" },
            { "binding_name": "#content_text" },
            { "binding_name": "#form_button_length" }
        ],
        "controls": [
            {
                "client_content": {
                    "type": "panel",
                    "controls": [
                        {
                            "tic_tac_toe_override": {
                                "type": "panel",
                                "bindings": [
                                    {
                                        "binding_name": "#title_text",
                                        "binding_name_override": "#title"
                                    }
                                ],
                                "controls": [
                                    {
                                        "grid_view": {
                                            "type": "panel",
                                            "layer": 1,
                                            "anchor_from": "center",
                                            "anchor_to": "center",
                                            "size": ["100%", "100%"],
                                            "controls": [{ "ttt_screen@addonexe_ttt.grid_screen": {} }]
                                        }
                                    }
                                ],
                                "visible": "($title_text = '§t§t§tTic Tac Toe')"
                            }
                        },
                        {
                            "default_view": {
                                "type": "stack_panel",
                                "orientation": "vertical",
                                "anchor_from": "top_middle",
                                "anchor_to": "top_middle",
                                "size": ["100%", "100%"],
                                "controls": [
                                    {
                                        "title_panel": {
                                            "type": "panel",
                                            "size": ["100%", 30],
                                            "controls": [
                                                {
                                                    "title": {
                                                        "type": "label",
                                                        "text": "#title_text",
                                                        "bindings": [{ "binding_name": "#title_text" }]
                                                    }
                                                }
                                            ]
                                        }
                                    },
                                    {
                                        "content_scroll": {
                                            "type": "scroll_view",
                                            "size": ["100%", "100%c"],
                                            "controls": [
                                                {
                                                    "content_stack": {
                                                        "type": "stack_panel",
                                                        "orientation": "vertical",
                                                        "size": ["100%", "100%c"],
                                                        "controls": [
                                                            {
                                                                "body_text": {
                                                                    "type": "label",
                                                                    "text": "#content_text",
                                                                    "size": ["100%", "default"],
                                                                    "bindings": [{ "binding_name": "#content_text" }]
                                                                }
                                                            },
                                                            {
                                                                "button_list_panel": {
                                                                    "type": "stack_panel",
                                                                    "orientation": "vertical",
                                                                    "size": ["100%", "100%c"],
                                                                    "factory": {
                                                                        "name": "buttons",
                                                                        "control_name": "server_form.form_button"
                                                                    },
                                                                    "collection_name": "form_buttons",
                                                                    "bindings": [
                                                                        {
                                                                            "binding_name": "#form_button_length",
                                                                            "binding_name_override": "#collection_length"
                                                                        }
                                                                    ]
                                                                }
                                                            }
                                                        ]
                                                    }
                                                }
                                            ]
                                        }
                                    }
                                ],
                                "visible": "(not ($title_text = '§t§t§tTic Tac Toe'))"
                            }
                        }
                    ]
                }
            }
        ]
    },
    "form_button": {
        "type": "button",
        "size": ["100%", 30],
        "controls": [
            {
                "label": {
                    "type": "label",
                    "text": "#button_text",
                    "bindings": [
                        {
                            "binding_name": "#button_text",
                            "binding_type": "collection",
                            "binding_collection_name": "form_buttons"
                        }
                    ]
                }
            }
        ],
        "button_mappings": [
            {
                "from_button_id": "button.menu_select",
                "to_button_id": "button.form_button_click",
                "mapping_type": "pressed"
            }
        ]
    }
}

{
  "format_version": "1.16.0",
  "minecraft:entity": {
    "description": {
      "identifier": "minecraft:zombie_villager_v2",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "minecraft:zombie_villager_baby": {
        "minecraft:is_baby": {},
        "minecraft:scale": {
          "value": 0.5
        },
        "minecraft:ageable": {
          "duration": -1,
          "feed_items": [],
          "grow_up": {
            "event": "minecraft:ageable_grow_up",
            "target": "self"
          }
        },
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 2,
          "must_see": true,
          "reselect_targets": true,
          "validation_query": {
            "any_of": [
              { "test": "is_family", "subject": "other", "value": "player" },
              { "test": "is_family", "subject": "other", "value": "irongolem" }
            ]
          }
        }
      },
      "minecraft:zombie_villager_adult": {
        "minecraft:experience_reward": {
          "on_death": "query.last_hit_by_player ? 5 + (query.equipment_count * Math.Random(1,3)) : 0"
        },
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 2,
          "must_see": true,
          "reselect_targets": true,
          "validation_query": {
            "any_of": [
              { "test": "is_family", "subject": "other", "value": "player" },
              { "test": "is_family", "subject": "other", "value": "irongolem" }
            ]
          }
        }
      },
      "minecraft:zombie_villager_cured": {
        "minecraft:transformation": {
          "into": "minecraft:villager_v2",
          "keep_owner": true
        }
      }
    },
    "components": {
      "minecraft:experience_reward": {
        "on_death": "query.last_hit_by_player ? 5 + (query.equipment_count * Math.Random(1,3)) : 0"
      },
      "minecraft:type_family": {
        "family": [ "zombie_villager", "zombie", "undead", "monster", "mob" ]
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0
      },
      "minecraft:nameable": {},
      "minecraft:collision_box": {
        "width": 0.6,
        "height": 1.9
      },
      "minecraft:movement": {
        "value": 0.23
      },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:health": {
        "value": 20,
        "max": 20
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": { "test": "in_lava", "subject": "self", "operator": "==", "value": true },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:attack": {
        "damage": 3
      },
      "minecraft:behavior.melee_attack": {
        "priority": 3
      },
      "minecraft:behavior.random_stroll": {
        "priority": 6,
        "speed_multiplier": 1
      },
      "minecraft:behavior.look_at_player": {
        "priority": 7,
        "look_distance": 6,
        "probability": 0.02
      },
      "minecraft:behavior.random_look_around": {
        "priority": 7
      },
      "minecraft:physics": {}
    },
    "events": {
      "minecraft:entity_spawned": {
        "randomize": [
          {
            "weight": 95,
            "add": {
              "component_groups": [ "minecraft:zombie_villager_adult" ]
            }
          },
          {
            "weight": 5,
            "add": {
              "component_groups": [ "minecraft:zombie_villager_baby" ]
            }
          }
        ]
      },
      "minecraft:cured": {
        "add": {
          "component_groups": [ "minecraft:zombie_villager_cured" ]
        },
        "remove": {
          "component_groups": [ "minecraft:zombie_villager_adult", "minecraft:zombie_villager_baby" ]
        }
      }
    }
  }
}

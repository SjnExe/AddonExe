{
    "compilerOptions": {
        "target": "ES2021",
        "module": "ES2020",
        "moduleResolution": "node",
        "strict": true,
        "allowJs": true,
        "checkJs": false,
        "outDir": "./AddonExeBP/scripts",
        "rootDir": "./src",
        "forceConsistentCasingInFileNames": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "incremental": true,
        "types": ["node", "@minecraft/server", "@minecraft/server-ui", "jest"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "src/**/__tests__"]
}
